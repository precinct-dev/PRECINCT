{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/uasgs/contracts/v2.4/schemas/plane_decision_v2.schema.json",
  "title": "UASGS Plane Decision V2",
  "type": "object",
  "required": [
    "decision",
    "reason_code",
    "envelope",
    "trace_id",
    "decision_id"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "quarantine",
        "step_up"
      ]
    },
    "reason_code": {
      "type": "string",
      "pattern": "^[A-Z0-9_]+$"
    },
    "envelope": {
      "$ref": "#/$defs/runEnvelope"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "runEnvelope": {
      "type": "object",
      "required": [
        "run_id",
        "session_id",
        "tenant",
        "actor_spiffe_id",
        "plane"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "tenant": {
          "type": "string",
          "minLength": 1
        },
        "actor_spiffe_id": {
          "type": "string",
          "minLength": 1
        },
        "plane": {
          "type": "string",
          "enum": [
            "ingress",
            "context",
            "model",
            "tool",
            "loop"
          ]
        },
        "execution_mode": {
          "type": "string"
        },
        "lineage_id": {
          "type": "string"
        },
        "parent_run_id": {
          "type": "string"
        },
        "parent_decision_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "decision_id": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
