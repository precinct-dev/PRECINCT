{
  "schema_version": "app.integration.pack.v1",
  "pack_id": "openclaw",
  "pack_version": "2026-02-21",
  "upstream": {
    "repo": "<upstream-openclaw-clone>",
    "branch": "main",
    "commit": "302fa03f4164094d6938ea3243889963230576d4"
  },
  "upstream_changelog": [
    {
      "from_commit": "5d40d47501",
      "to_commit": "302fa03f41",
      "date": "2026-02-21",
      "http_api_changes": "none",
      "ws_protocol_changes": [
        "node role now requires device identity during connect (ddcb2d79b)",
        "allowInsecureAuth config deprecated; only dangerouslyDisableDeviceAuth honored (protocol.md)",
        "auth surface refactored: separate HTTP vs WS authorize functions (36a0df423)",
        "role-policy and connect-policy extracted to separate modules (51149fcaf)"
      ],
      "adapter_impact": "WS adapter updated to enforce device-identity for node role"
    }
  ],
  "ownership": {
    "model": "sdk_plus_pack",
    "core_policy": "gateway_core"
  },
  "routes": {
    "http": [
      "/v1/responses",
      "/tools/invoke"
    ],
    "ws": [
      "/openclaw/ws"
    ]
  },
  "adapter_contract": {
    "model_routing": {
      "default_provider": "gateway_mediated",
      "strategy": "allowlist",
      "allowed_models": [
        "llama-3.3-70b-versatile"
      ],
      "provider_env_hints": [
        "GROQ_API_KEY"
      ],
      "fallback_behavior": "gateway_policy_controlled"
    },
    "tool_registration": {
      "registry_source": "gateway_registry",
      "required_tools": [
        "tavily_search",
        "read",
        "bash"
      ],
      "forbid_unregistered_tools": true,
      "hash_verification": "required"
    },
    "gateway_guardrails": {
      "prompt_injection_protection": "dlp_flag_plus_guard_model",
      "mission_boundary": {
        "agent_purpose": "device_operations_support",
        "default_mode": "enforce",
        "allowed_intents": [
          "connectivity_help",
          "device_health",
          "device_ping",
          "device_list",
          "operator_guidance"
        ],
        "allowed_topics": [
          "device",
          "node",
          "health",
          "ping",
          "operator",
          "connect"
        ],
        "blocked_topics": [
          "python",
          "linked list",
          "recipe",
          "food order"
        ],
        "out_of_scope_action": "rewrite"
      },
      "enforced_controls": [
        "spiffe_auth",
        "opa_policy",
        "tool_registry_verify",
        "dlp_scan",
        "step_up_gating",
        "audit_chain"
      ],
      "decision_contract": {
        "deny_codes": [
          "registry_tool_unknown",
          "registry_hash_mismatch",
          "deepscan_blocked",
          "dlp_credentials_detected",
          "ws_device_required"
        ],
        "timeout_behavior_non_strict": "accept_case26_gateway_timeout_variance",
        "timeout_behavior_strict": "fail_closed"
      }
    },
    "runtime_profile_hints": {
      "compose": {
        "strict_deepscan": true,
        "preferred_validation": [
          "make demo-compose"
        ]
      },
      "k8s": {
        "strict_deepscan": false,
        "preferred_validation": [
          "make demo-k8s"
        ],
        "known_variance": [
          "case26_model_route_timeout_non_strict"
        ]
      }
    }
  },
  "security_expectations": {
    "no_upstream_source_modification": true,
    "no_direct_model_bypass": true,
    "no_direct_tool_bypass": true,
    "required_controls": [
      "spiffe_auth",
      "opa_policy",
      "tool_registry_verify",
      "dlp_scan",
      "step_up_gating",
      "audit_chain"
    ]
  },
  "runtime_validation": {
    "compose": [
      "make demo-compose"
    ],
    "k8s": [
      "make demo-k8s"
    ]
  }
}
