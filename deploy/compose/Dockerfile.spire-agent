# Custom SPIRE Agent with shell support for dynamic token reading
# Needs shell for wrapper script; uses Alpine (pinned) with non-root user.

FROM ghcr.io/spiffe/spire-agent:1.10.0@sha256:6ce32791b34165305fbdf2fbbf3931fd2163a9c02bdef8fc63833d53ef5572cb AS spire
FROM alpine:3.21@sha256:c3f8e73fdb79deaebaa2037150150191b9dcbfba68b4a46d70103204c53f4709

# Create non-root user
RUN addgroup -g 1000 spire && \
    adduser -D -u 1000 -G spire -s /sbin/nologin spire

# Copy SPIRE agent binaries from official image
COPY --from=spire /opt/spire/bin/spire-agent /opt/spire/bin/spire-agent

# Create required directories owned by non-root user
RUN mkdir -p /opt/spire/data/agent /opt/spire/conf/agent /token && \
    chown -R spire:spire /opt/spire /token

# Copy the entrypoint wrapper script
COPY scripts/spire-agent-wrapper.sh /entrypoint-wrapper.sh
RUN chmod +x /entrypoint-wrapper.sh

# Set working directory
WORKDIR /opt/spire

USER spire

# Use our wrapper as entrypoint
ENTRYPOINT ["/entrypoint-wrapper.sh"]
