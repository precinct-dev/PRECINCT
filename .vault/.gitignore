# nd runtime state -- do not track
# Issues are the system of record and ARE tracked in git
.nd.yaml
.vlt.lock
.trash/
.guard/
.piv-loop-state.json
.piv-loop-snapshot.json
.dispatcher-state.json

# Issues are the system of record; use `nd archive` for git-committable snapshots
issues/

# Default mode keeps .nd.yaml and issues/ local; use `nd init --track-issues` to track them in git
