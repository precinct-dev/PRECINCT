{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/conformance-report-v1.json",
  "title": "Conformance Report V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "harness",
    "generated_at",
    "suites",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "conformance.report.v1"
    },
    "harness": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "suites": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["suite", "status", "checks"],
        "properties": {
          "suite": {
            "type": "string",
            "enum": ["connectors", "contracts", "profiles", "ruleops"]
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "case_id", "expected", "actual", "status", "message"],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "case_id": {
                  "type": "string",
                  "minLength": 1
                },
                "expected": {
                  "type": "string",
                  "enum": ["pass", "fail"]
                },
                "actual": {
                  "type": "string",
                  "enum": ["pass", "fail"]
                },
                "status": {
                  "type": "string",
                  "enum": ["pass", "fail"]
                },
                "message": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_suites",
        "suite_pass",
        "suite_fail",
        "total_checks",
        "check_pass",
        "check_fail"
      ],
      "properties": {
        "total_suites": {
          "type": "integer",
          "minimum": 0
        },
        "suite_pass": {
          "type": "integer",
          "minimum": 0
        },
        "suite_fail": {
          "type": "integer",
          "minimum": 0
        },
        "total_checks": {
          "type": "integer",
          "minimum": 0
        },
        "check_pass": {
          "type": "integer",
          "minimum": 0
        },
        "check_fail": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
